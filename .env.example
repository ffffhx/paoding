# 庖丁引擎配置 —— 复制为 .env 并填好，或直接 export 到环境变量。
#
# 有两套推荐配置，二选一：
#   A. 全本地零成本（Ollama + 本地 whisper.cpp）—— 不花钱、不出本机，Mac 首选
#   B. 云端（OpenAI 兼容接口 + Whisper 云端）—— 讲解质量上限更高
# ====================================================================

# ---------- A. 全本地零成本（推荐先用这套） ----------
# 大模型走 Ollama 的 OpenAI 兼容接口（先 `ollama pull qwen2.5:14b`）
PAODING_LLM_BASE_URL=http://localhost:11434/v1
PAODING_LLM_API_KEY=ollama
PAODING_LLM_MODEL=qwen2.5:14b

# 语音转文字走本地 whisper.cpp（先 `brew install whisper-cpp` 并下载模型，见 README）
PAODING_ASR_PROVIDER=local
PAODING_WHISPER_MODEL=./models/ggml-large-v3-turbo.bin
# PAODING_WHISPER_BIN=whisper-cli
# PAODING_ASR_LANG=zh

# ---------- 视觉模型（可选，两个功能共用）----------
# 设了才可用：① 读画面字幕（OCR，兜住「没口播只有字幕」的视频）② 提取画面截图（每步状态图 + 食材图）。
# 两个功能都在解析时按次勾选（CLI 用 --images），且都会改为下载完整视频（更慢更占带宽）。
# 本地：先 `ollama pull qwen2.5vl:7b`，默认复用上面的 LLM 接口。
# PAODING_VISION_MODEL=qwen2.5vl:7b
# PAODING_VISION_MAX_FRAMES=20
# 若视觉走另一个服务：PAODING_VISION_BASE_URL / PAODING_VISION_API_KEY

# ---------- B. 云端（把上面注释掉，用这套） ----------
# PAODING_LLM_BASE_URL=https://api.openai.com/v1
# PAODING_LLM_API_KEY=sk-xxxx
# PAODING_LLM_MODEL=gpt-4o-mini
# PAODING_ASR_PROVIDER=openai
# PAODING_ASR_MODEL=whisper-1
# 若 ASR 走另一个服务，单独覆盖：PAODING_ASR_BASE_URL / PAODING_ASR_API_KEY

# ---------- 视频下载（yt-dlp）----------
# B站/部分平台反爬(HTTP 412)时，用浏览器已登录的 cookie 绕过。留空则不带。
# 可选值：chrome | safari | edge | firefox | brave …
# PAODING_COOKIES_FROM_BROWSER=chrome

# ---------- App 后端鉴权（可选，但公网/隧道暴露时强烈建议）----------
# 设了它，所有 /api/* 请求都要带上同一 token（App 设置页「API Token」里填一致的值）。
# 不设 = 不鉴权（仅本机/可信局域网时可留空）。生成示例：openssl rand -hex 16
# PAODING_API_TOKEN=

# ---------- 通用可选 ----------
# PAODING_OUT_DIR=./paoding-out
# 讲解深度：beginner | balanced | advanced（默认 balanced）
# PAODING_DEPTH=balanced
# 单个解析任务超时（分钟，默认 20）。超时释放并发额度、报错让用户重试，避免卡死的 yt-dlp/ffmpeg 永久占槽。
# PAODING_JOB_TIMEOUT_MIN=20
# 单次导入菜谱上限（默认 5000）
# PAODING_MAX_IMPORT=5000
